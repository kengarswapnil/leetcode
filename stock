public class Main {
 public static void stock(int arr[]){
  int n = arr.length;
  int res = 0;
  
  for(int i=0;i<arr.length;i++){
   for(int j=i+1;j<arr.length;j++){
    res = Math.max(res,arr[j]-arr[i]);
   }
  }
  System.out.println(res);
  
  
 }
 public static void main(String[] args) {
  int arr[]={1,2,3,4,5,6};
  stock(arr);
 }
}

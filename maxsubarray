public class Main {
 public static void main(String[] args) {
  int arr [] = {1,2,3,4,5};
  int max = Integer.MIN_VALUE;
  for(int i=0;i<arr.length;i++){
   int sum = 0;
   for(int j=i+1;j<arr.length;j++){
      sum += arr[j];
      
      if(sum > max){
       max = sum;
      }
   }
  }
  System.out.println(max);
 }
}
